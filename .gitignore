# ───── Secrets — MAI committare ─────
secrets/*
!secrets/.gitkeep
!secrets/README.md
.env
.env.local
.env.*.local

# ───── Export di sessione — MAI committare ─────
# `/export` di una sessione di lavoro produce AAAA-MM-GG-HHMMSS-<slug>.txt: è il
# transcript completo di quello che ci si è detti lavorando — password incollate,
# IP, path locali, dati personali. Non ha l'aria di un segreto (è un .txt con un
# nome innocuo) ed è esattamente per questo che è il file più pericoloso del repo.
# Tienili fuori: se ti serve conservarli, mettili in una cartella fuori dal repo.
# La rete di sicurezza a valle è `security/check_no_leaks.py`, in CI — perché
# questa riga non ferma `git add -f` né salva un file già tracciato.
20[0-9][0-9]-[0-9][0-9]-[0-9][0-9]-[0-9][0-9][0-9][0-9][0-9][0-9]-*.txt

# ───── Build / cache ─────
__pycache__/
*.py[cod]
*$py.class
.venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
node_modules/
dist/
build/

# ───── Backups + dati runtime ─────
backups/
data/*
!data/.gitkeep
volumes/

# ───── Self-update runtime (esiste solo sulla VPS) ─────
var/
releases/

# ───── Onboarding pending (valori sensibili temporanei) ─────
onboarding/

# ───── IDE / OS ─────
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# ───── Dev artifacts ─────
coverage.xml
htmlcov/
.tox/
*.log
*.pid
*.sock

# ───── Compose ─────
docker-compose.override.yml
compose.override.yaml
compose.local.yaml
