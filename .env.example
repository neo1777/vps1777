# vps1777 — .env.example
#
# Copia in `.env` e compila. `.env` è gitignored, MAI committare.
# Per i secret veri (password, token, key) usa secrets/*.txt — vedi docs/SECRETS.md.

# ──────────────────────────────────────────────────────────────────────
# IDENTITÀ DEL DEPLOY
# ──────────────────────────────────────────────────────────────────────

# Email admin OAuth (l'owner del gateway, unico utente OAuth)
ADMIN_EMAIL=tu@gmail.com

# Telegram OWNER_ID (numerico, da @userinfobot)
TELEGRAM_OWNER_ID=123456789

# URL pubblico del tuo gateway. Lasciato vuoto → loopback dev.
# Esempi:
#   PUBLIC_BASE=https://nome.tail0c1f07.ts.net   # Tailscale Funnel
#   PUBLIC_BASE=https://vps.tuodominio.com       # Caddy + tuo DNS
#   PUBLIC_BASE=https://abc.cfargotunnel.com     # Cloudflare Tunnel
PUBLIC_BASE=

# Tag immagini (semver in produzione, "dev" in sviluppo)
VPS1777_TAG=dev

# ──────────────────────────────────────────────────────────────────────
# UPSTREAMS — il gateway routes /<SECRET>/<name>/... → <host>:<port>
# ──────────────────────────────────────────────────────────────────────
# Formato CSV: name=host:port,name=host:port,...
# Aggiungi qui i tuoi plugin MCP. host = nome del service in compose.
GATEWAY_UPSTREAMS=archive=archive-mcp:8002,nb1777=nb1777-mcp:8003

# ──────────────────────────────────────────────────────────────────────
# INGRESS — scegli UNO dei 3 profili (gestisce HTTPS pubblico)
# ──────────────────────────────────────────────────────────────────────
#
# Tailscale Funnel:
#   docker compose --profile ingress.tailscale up -d
#   Vedi: secrets/ts_authkey.txt + variabili TS_*
#
# Caddy (LE su tuo dominio):
#   docker compose --profile ingress.caddy up -d
#   Vedi: CADDY_DOMAIN, CADDY_EMAIL
#
# Cloudflared (CF Tunnel):
#   docker compose --profile ingress.cloudflared up -d
#   Vedi: secrets/cloudflared_token.txt

TS_HOSTNAME=                 # opzionale, hostname Tailscale (es. vps1777)
CADDY_DOMAIN=                # es. vps.tuodominio.com
CADDY_EMAIL=                 # tua email per Let's Encrypt
