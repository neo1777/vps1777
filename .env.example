# vps1777 — .env.example
#
# Copia in `.env` e compila. `.env` è gitignored, MAI committare.
# Per i secret veri (password, token, key) usa secrets/*.txt — vedi docs/SECRETS.md.

# ──────────────────────────────────────────────────────────────────────
# IDENTITÀ DEL DEPLOY
# ──────────────────────────────────────────────────────────────────────

# Email admin OAuth (l'owner del gateway, unico utente OAuth)
ADMIN_EMAIL=tu@gmail.com

# Telegram OWNER_ID (numerico, da @userinfobot)
TELEGRAM_OWNER_ID=123456789

# URL pubblico del tuo gateway. Lasciato vuoto → loopback dev.
# Esempi:
#   PUBLIC_BASE=https://nome.tail0c1f07.ts.net   # Tailscale Funnel
#   PUBLIC_BASE=https://vps.tuodominio.com       # Caddy + tuo DNS
#   PUBLIC_BASE=https://abc.cfargotunnel.com     # Cloudflare Tunnel
PUBLIC_BASE=

# Tag immagini deployato (semver). In produzione lo scrivono SOLO
# `vps1777 update/rollback/bootstrap` e l'installer — non editare a mano.
# "dev" solo in sviluppo locale (con compose.build.yaml).
VPS1777_TAG=dev

# Base del registry immagini. Fork o registry alternativo: cambia solo questa.
VPS1777_IMAGE_BASE=ghcr.io/neo1777

# ──────────────────────────────────────────────────────────────────────
# OPZIONALI (vuoti = feature spenta)
# ──────────────────────────────────────────────────────────────────────
# Archivio di ricerca (archive-mcp): nasce VUOTO. Per popolarlo, metti i tuoi
# DB SQLite FTS5 nel volume archive-data e dichiarali qui come CSV nome:path.
# ARCHIVE_DB_PATHS=main:/var/lib/archive/db/main.db,note:/var/lib/archive/db/note.db

# State card NotebookLM: se imposti l'id di un notebook, dopo ogni
# `vps1777 update` (o rollback) la VPS vi fa upsert di una card con
# versione + contratto tool (best-effort, non blocca mai l'update). La verità
# viva resta il tool `doctor`; la card serve ai contesti che leggono il
# notebook senza l'MCP. Vuoto = spenta.
# VPS1777_STATECARD_NB=

# ──────────────────────────────────────────────────────────────────────
# UPSTREAMS — il gateway routes /<SECRET>/<name>/... → <host>:<port>
# ──────────────────────────────────────────────────────────────────────
# Formato CSV: name=host:port,name=host:port,...
# Aggiungi qui i tuoi plugin MCP. host = nome del service in compose.
GATEWAY_UPSTREAMS=archive=archive-mcp:8002,nb1777=nb1777-mcp:8003

# ──────────────────────────────────────────────────────────────────────
# INGRESS — scegli UNO dei 3 profili (gestisce HTTPS pubblico)
# ──────────────────────────────────────────────────────────────────────
#
# Tailscale Funnel (Tailscale gira SULL'HOST, non in container):
#   L'installer installa Tailscale sull'host e fa up + serve + funnel verso
#   il gateway su 127.0.0.1:8080. Richiede a livello account:
#   MagicDNS + HTTPS Certificates + nodeAttr funnel. Vedi docs/INGRESS.md.
#   GATEWAY_BIND controlla l'esposizione del gateway:
#     127.0.0.1 = solo loopback (produzione, lo vede solo il Funnel)
#     0.0.0.0   = fallback raggiungibile via http://IP:8080 (se il Funnel non parte)
GATEWAY_BIND=127.0.0.1
#
# Caddy (LE su tuo dominio):
#   docker compose --profile ingress.caddy up -d
#   Vedi: CADDY_DOMAIN, CADDY_EMAIL
#
# Cloudflared (CF Tunnel):
#   docker compose --profile ingress.cloudflared up -d
#   Vedi: secrets/cloudflared_token.txt

TS_HOSTNAME=                 # opzionale, hostname Tailscale (es. vps1777)
TS_AUTHKEY=                  # Tailscale auth-key (manuale); con l'installer la genera l'OAuth client
CADDY_DOMAIN=                # es. vps.tuodominio.com
CADDY_EMAIL=                 # tua email per Let's Encrypt
